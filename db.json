"modified":1452566715780,"shasum":"9cdd4967d97b21c122e0a60218c3c82c18ce1aeb"},{"_id":"public/archives/index.html","modified":1452566715797,"shasum":"fdb9b11e095a5c2b2c7f38924f6547ba24f8ee03"},{"_id":"public/archives/2016/index.html","modified":1452566715813,"shasum":"0f11c2a0bf2010ea11b20adad37686d5f2b351d8"},{"_id":"public/archives/2016/01/index.html","modified":1452566715830,"shasum":"ebe57aa80f956e85f85324efd0201491c459f38d"},{"_id":"public/index.html","modified":1452566715861,"shasum":"c01bf04df3d579278af28c51e8eac2e84a894406"}],"Category":[],"Data":[],"Page":[],"Post":[{"title":"Front End Skill","date":"2016-01-11T03:26:10.000Z","_content":"1.Html\n  1.当form表单只有一个input text的时候，input text触发回车按钮会自动提交表单。\n\n2.Javascript\n  判断变量是否存在，不能用if(未定义变量)，可以用window.aa代替。","source":"_posts/Front End Skill.md","raw":"title: Front End Skill\ndate: 2016-01-11 11:26:10\ntags: 前端\n---\n1.Html\n  1.当form表单只有一个input text的时候，input text触发回车按钮会自动提交表单。\n\n2.Javascript\n  判断变量是否存在，不能用if(未定义变量)，可以用window.aa代替。","slug":"Front End Skill","published":1,"updated":"2016-01-11T08:04:46.099Z","comments":1,"layout":"post","photos":[],"link":"","_id":"cijasptj80000o8jxx4h4qrtp"},{"title":"阅读信息分享系统开发计划与流程","date":"2016-01-07T10:06:10.000Z","_content":"\n系统开发计划\n\n  2016.1.11 ~ 2016.1.14\n    撰写系统初步论文\n\n  2016.1.15 ~ 2016.1.20\n    架构和搭建系统结构\n\n  2016.1.21 ~ 2016.3.21\n    系统设计\n\n  2016.3.21 ~ \n    系统测试及完善毕业论文\n\n系统开发流程\n\n  系统框架确认\n\n  后台架构搭建\n\n  前台端登录模块实现\n\n  前台端游客模块实现\n\n  前台端个人模块实现\n\n  前台端后台管理系统实现\n  \n\n\n","source":"_posts/阅读信息分享系统开发计划与流程.md","raw":"title: 阅读信息分享系统开发计划与流程\ndate: 2016-01-07 18:06:10\ntags: 前端\n---\n\n系统开发计划\n\n  2016.1.11 ~ 2016.1.14\n    撰写系统初步论文\n\n  2016.1.15 ~ 2016.1.20\n    架构和搭建系统结构\n\n  2016.1.21 ~ 2016.3.21\n    系统设计\n\n  2016.3.21 ~ \n    系统测试及完善毕业论文\n\n系统开发流程\n\n  系统框架确认\n\n  后台架构搭建\n\n  前台端登录模块实现\n\n  前台端游客模块实现\n\n  前台端个人模块实现\n\n  前台端后台管理系统实现\n  \n\n\n","slug":"阅读信息分享系统开发计划与流程","published":1,"updated":"2016-01-11T08:04:46.099Z","comments":1,"layout":"post","photos":[],"link":"","_id":"cijasptlg0003o8jx618i68tu"},{"title":"浏览器兼容性问题","date":"2016-01-11T03:26:10.000Z","_content":"1. IE浏览器\n  1. 当input text的value为空时，value值会被placeholder值取代\n  2.IE浏览器不兼容CSS：initial    \n  3.IE8不支持String.trim()方法\n  4.IE8不支持rgba，仅支持rgb\n  5.IE8不支持媒体查询\n  6.IE8不支持圆角\n  7.IE8不支持delete、put等http请求方式\n  8.IE8 li 默认有float:left属性\n2. IOS系统\n  1.IOS系统下的浏览器对new Date(\"2015-01-01 09:09:09\")判定为Invalid Date，而其他系统能成功初始化。\n\n3. FireFox浏览器\n  2.FireFox浏览器和IE浏览器对new Date('2015-12-8')判定为Invalid Date，而Chrome浏览器能成功初始化。","source":"_posts/浏览器兼容性问题.md","raw":"title: 浏览器兼容性问题\ndate: 2016-01-11 11:26:10\ntags: 前端\n---\n1. IE浏览器\n  1. 当input text的value为空时，value值会被placeholder值取代\n  2.IE浏览器不兼容CSS：initial    \n  3.IE8不支持String.trim()方法\n  4.IE8不支持rgba，仅支持rgb\n  5.IE8不支持媒体查询\n  6.IE8不支持圆角\n  7.IE8不支持delete、put等http请求方式\n  8.IE8 li 默认有float:left属性\n2. IOS系统\n  1.IOS系统下的浏览器对new Date(\"2015-01-01 09:09:09\")判定为Invalid Date，而其他系统能成功初始化。\n\n3. FireFox浏览器\n  2.FireFox浏览器和IE浏览器对new Date('2015-12-8')判定为Invalid Date，而Chrome浏览器能成功初始化。","slug":"浏览器兼容性问题","published":1,"updated":"2016-01-11T08:04:46.099Z","comments":1,"layout":"post","photos":[],"link":"","_id":"cijasptlw0005o8jxt675kasw"},{"title":"seajs","date":"2016-01-11T03:26:10.000Z","_content":"\n//exports 暴露引入\n\n//require 引入依赖\n\n//模块内的引入依赖和暴露接口\ndefine(function (require, exports) {\n  var util = require('./util.js');\n  exports.init = function () {\n    // Todo:\n  }\n});\n\n//页面引入模块\nseajs.use('dialog', function (Dialog) {\n  // Todo: Dialog.init();\n});","source":"_posts/seajs.md","raw":"title: seajs\ndate: 2016-01-11 11:26:10\ntags: 前端\n---\n\n//exports 暴露引入\n\n//require 引入依赖\n\n//模块内的引入依赖和暴露接口\ndefine(function (require, exports) {\n  var util = require('./util.js');\n  exports.init = function () {\n    // Todo:\n  }\n});\n\n//页面引入模块\nseajs.use('dialog', function (Dialog) {\n  // Todo: Dialog.init();\n});","slug":"seajs","published":1,"updated":"2016-01-11T08:04:46.099Z","comments":1,"layout":"post","photos":[],"link":"","_id":"cijasptm40007o8jx65c5c4y6"},{"title":"rails 环境安装手册","date":"2016-01-11T03:26:10.000Z","_content":"\n安装 vim, git , npm\nsudo apt-get install vim git npm\n\n生成ssh key\nssh-keygen -t rsa -C “dfyu@xtremeprog.com”\ncat ~/.ssh/id_rsa.pub #这个是放在gitlab上面的\n\n安装rvm, ruby, rails\n\n#rvm\ncurl -L get.rvm.io #测试网络\ncurl -L get.rvm.io | bash -s stable #下载安装\n执行 vim ~/.bashofile，在后面添加 [ -f $HOME/.profile ] && source $HOME/.profile\n\nsed -i ‘s!ftp.ruby-lang.org/pub/ruby!ruby.taobao.org/mirrors/ruby!’ $rvm_path/config/db #将rvm的资源地址换到taobao\nrvm -v #测试rvm\n\n#ruby\nrvm list known #查看有哪些版本可以装\nrvm install 2.1.5 #选择某个版本.\nrvm use ruby-2.1.5 –default #选择默认版本\nruby -v #查看版本.\n\n更改gem源\ngem sources –remove https://rubygems.org/\ngem sources –add https://ruby.taobao.org/ #注意是https\ngem sources -l #保证只有一个\n\n#rails\ngem install rails -v 4.1.1\n\n#安装mysql依赖包\nsudo apt-get install libmysqlclient-dev\n\n#bundle\ngem install bundle –no-rdoc –no-ri #不装文档\n\n#nvm\ngit clone https://github.com/creationix/nvm.git ~/.nvm\n然后打开~/.bash_profile文件，在其中添加：source ~/.nvm/nvm.sh\nnvm install (node的版本号)\n然后ln -s 源文件 目标文件 设置软连接到/usr/sbin里","source":"_posts/rails.md","raw":"title: rails 环境安装手册\ndate: 2016-01-11 11:26:10\ntags: 环境配置\n---\n\n安装 vim, git , npm\nsudo apt-get install vim git npm\n\n生成ssh key\nssh-keygen -t rsa -C “dfyu@xtremeprog.com”\ncat ~/.ssh/id_rsa.pub #这个是放在gitlab上面的\n\n安装rvm, ruby, rails\n\n#rvm\ncurl -L get.rvm.io #测试网络\ncurl -L get.rvm.io | bash -s stable #下载安装\n执行 vim ~/.bashofile，在后面添加 [ -f $HOME/.profile ] && source $HOME/.profile\n\nsed -i ‘s!ftp.ruby-lang.org/pub/ruby!ruby.taobao.org/mirrors/ruby!’ $rvm_path/config/db #将rvm的资源地址换到taobao\nrvm -v #测试rvm\n\n#ruby\nrvm list known #查看有哪些版本可以装\nrvm install 2.1.5 #选择某个版本.\nrvm use ruby-2.1.5 –default #选择默认版本\nruby -v #查看版本.\n\n更改gem源\ngem sources –remove https://rubygems.org/\ngem sources –add https://ruby.taobao.org/ #注意是https\ngem sources -l #保证只有一个\n\n#rails\ngem install rails -v 4.1.1\n\n#安装mysql依赖包\nsudo apt-get install libmysqlclient-dev\n\n#bundle\ngem install bundle –no-rdoc –no-ri #不装文档\n\n#nvm\ngit clone https://github.com/creationix/nvm.git ~/.nvm\n然后打开~/.bash_profile文件，在其中添加：source ~/.nvm/nvm.sh\nnvm install (node的版本号)\n然后ln -s 源文件 目标文件 设置软连接到/usr/sbin里","slug":"rails","published":1,"updated":"2016-01-11T08:04:46.099Z","comments":1,"layout":"post","photos":[],"link":"","_id":"cijasptm90009o8jxwp08m2eo"},{"title":"hexo备份整个blog","date":"2016-01-11T03:26:10.000Z","_content":"通过hexo新建了一个blog之后，github上面只有blog的静态文件，若要备份整个blog的项目。可通过以下步奏\n  1. git clone ... #先拉blog代码\n\n  2. git branch hexo #新建一个hexo分支 \n\n  3. git checkout hexo #切换hexo分支\n\n  4. 清除项目文件，并将全部blog文件复制进来\n\n  5. git add -A, git commit -m '...', git push origin hexo:hexo\n\n  6. github设置hexo为默认分支\n\n  7. touch gitignore #新建.gitignore\n\n  8. 设置gitignore ,ignore(/node_modules/, /.deploy_git/)\n\n  9. hexo clean #重置hexo\n提交blog代码有两个步奏\n  \n  1. 若要重新部署Blog, hexo g, hexo d #hexo 默认推送代码到master，可在_config.yml更改\n\n  2. 若要备份Blog, git add -A, git commit -m '..', git push origin hexo\n\n\n","source":"_posts/hexo.md","raw":"title: hexo备份整个blog\ndate: 2016-01-11 11:26:10\ntags: [hexo, git]\n---\n通过hexo新建了一个blog之后，github上面只有blog的静态文件，若要备份整个blog的项目。可通过以下步奏\n  1. git clone ... #先拉blog代码\n\n  2. git branch hexo #新建一个hexo分支 \n\n  3. git checkout hexo #切换hexo分支\n\n  4. 清除项目文件，并将全部blog文件复制进来\n\n  5. git add -A, git commit -m '...', git push origin hexo:hexo\n\n  6. github设置hexo为默认分支\n\n  7. touch gitignore #新建.gitignore\n\n  8. 设置gitignore ,ignore(/node_modules/, /.deploy_git/)\n\n  9. hexo clean #重置hexo\n提交blog代码有两个步奏\n  \n  1. 若要重新部署Blog, hexo g, hexo d #hexo 默认推送代码到master，可在_config.yml更改\n\n  2. 若要备份Blog, git add -A, git commit -m '..', git push origin hexo\n\n\n","slug":"hexo","published":1,"updated":"2016-01-12T02:45:01.397Z","comments":1,"layout":"post","photos":[],"link":"","_id":"cijasptmc000co8jx4cbipezt"},{"title":"express.js","date":"2016-01-11T07:43:00.000Z","_content":" # 安装express\n\n  sudo npm install express express-generator -g #安装express\n  \n  express readToShareSystem #创建express项目\n\n  cd readToShareSystem\n\n  npm install #安装express依赖包\n\n  npm start 或者 DEBUG=myapp npm start","source":"_posts/expressJs.md","raw":"title: express.js\ndate: 2016-01-11 15:43:00\ntags: 前端\n---\n # 安装express\n\n  sudo npm install express express-generator -g #安装express\n  \n  express readToShareSystem #创建express项目\n\n  cd readToShareSystem\n\n  npm install #安装express依赖包\n\n  npm start 或者 DEBUG=myapp npm start","slug":"expressJs","published":1,"updated":"2016-01-11T09:34:02.411Z","comments":1,"layout":"post","photos":[],"link":"","_id":"cijasptmg000ho8jx6pat7tml"}],"PostAsset":[],"PostCategory":[],"PostTag":[{"post_id":"cijasptj80000o8jxx4h4qrtp","tag_id":"cijasptjk0001o8jxus8kz84i","_id":"cijasptjn0002o8jxbkz937tg"},{"post_id":"cijasptlg0003o8jx618i68tu","tag_id":"cijasptjk0001o8jxus8kz84i","_id":"cijasptlj0004o8jxu823xeyu"},{"post_id":"cijasptlw0005o8jxt675kasw","tag_id":"cijasptjk0001o8jxus8kz84i","_id":"cijasptm00006o8jx4t01vb1b"},{"post_id":"cijasptm40007o8jx65c5c4y6","tag_id":"cijasptjk0001o8jxus8kz84i","_id":"cijasptm60008o8jxqfm8y4v0"},{"post_id":"cijasptm90009o8jxwp08m2eo","tag_id":"cijasptma000ao8jxxlmvgmve","_id":"cijasptmb000bo8jxldbgos99"},{"post_id":"cijasptmc000co8jx4cbipezt","tag_id":"cijasptme000do8jxdgilj9wy","_id":"cijasptme000fo8jxx8n7plve"},{"post_id":"cijasptmc000co8jx4cbipezt","tag_id":"cijasptme000eo8jxnaitm4fh","_id":"cijasptme000go8jxc27wx0eo"},{"post_id":"cijasptmg000ho8jx6pat7tml","tag_id":"cijasptjk0001o8jxus8kz84i","_id":"cijasptmh000io8jxz74145hq"}],"Tag":[{"name":"前端","_id":"cijasptjk0001o8jxus8kz84i"},{"name":"环境配置","_id":"cijasptma000ao8jxxlmvgmve"},{"name":"hexo","_id":"cijasptme000do8jxdgilj9wy"},{"name":"git","_id":"cijasptme000eo8jxnaitm4fh"}]}}